# Copy this file to android/app/key.properties and fill in the values.
# NEVER commit key.properties to source control.
#
# Generate a keystore with:
#   keytool -genkeypair -v -keystore release.jks -alias drivelogic \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile: absolute or relative path to the .jks/.keystore file
storeFile=/path/to/release.jks
storePassword=your_store_password
keyAlias=drivelogic
keyPassword=your_key_password
